{
  "name": "paint-room-dj",
  "version": "0.3.0",
  "description": "Minimal Electron app with file access, MIDI, and audio playback",
  "author": "Aaron Strick",
  "main": "app/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "build": {
    "appId": "com.paintroomdj.app",
    "productName": "paint-room-dj",
    "mac": {
      "category": "public.app-category.music",
      "target": "dmg"
    },
    "directories": {
      "output": "dist/build"
    },
    "files": [
      "app/main.js",
      "app/preload.js",
      "app/renderer/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.0.0"
  }
}
